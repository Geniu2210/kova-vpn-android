<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:background="@drawable/kova_background">

        <!-- TOP BAR -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp"
            android:background="@color/md_theme_surface">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"/>
        </com.google.android.material.appbar.AppBarLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color_light"/>

        <!-- CENTER CONTENT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- CENTER VERTICAL STACK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="32dp">

                <!-- HINT TEXT -->
                <TextView
                    android:id="@+id/tv_vpn_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_tap_to_connect"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:layout_marginBottom="48dp"/>

                <!-- POWER BUTTON -->
                <FrameLayout
                    android:id="@+id/fab_power"
                    android:layout_width="164dp"
                    android:layout_height="164dp"
                    android:background="@drawable/bg_power_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:layout_gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/iv_power_icon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_power_24dp"
                        app:tint="@color/colorWhite"/>

                </FrameLayout>

                <!-- STATUS TEXT -->
                <TextView
                    android:id="@+id/tv_test_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="40dp"
                    android:text="@string/vpn_disconnected"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="15sp"
                    android:gravity="center"/>

                <!-- TRAFFIC CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_traffic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/md_theme_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/traffic_upload"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tv_upload"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider_color_light"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/traffic_download"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tv_download"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PER-APP LINK -->
                <TextView
                    android:id="@+id/tv_per_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:paddingVertical="8dp"
                    android:text="@string/per_app_proxy_settings"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- FAB SERVER LIST -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_locate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_server_list_24dp"
                android:contentDescription="@string/title_server"
                app:backgroundTint="@color/md_theme_secondaryContainer"
                app:tint="@color/md_theme_onSecondaryContainer"
                app:useCompatPadding="true"/>

            <!-- Hidden FAB kept for code compat -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="80dp"
                android:visibility="gone"
                android:src="@drawable/ic_play_24dp"
                app:useCompatPadding="true"/>

        </RelativeLayout>
    </LinearLayout>

    <!-- DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/md_theme_surface"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_drawer"/>

</androidx.drawerlayout.widget.DrawerLayout>
